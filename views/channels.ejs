<div class="page-header">
  <div>
    <h2 class="page-title">频道监控</h2>
    <p class="page-subtitle">保存直播间链接，自动检测开播状态，开播后可自动启动转推任务。</p>
  </div>
  <div class="flex" style="gap:8px">
    <button onclick="checkAll(this)" class="btn btn-secondary">全部检测</button>
    <button onclick="document.getElementById('add-modal').classList.remove('hidden')" class="btn btn-primary">+ 添加频道</button>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error section"><%= error %></div>
<% } %>

<div class="alert alert-info section">
  每 5 分钟自动检测一次开播状态（需要至少一台在线 VPS 提供 yt-dlp 支持）。开播后若开启「自动启动」，将自动创建并启动转推任务。
</div>

<div class="card section">
  <div class="card-header">
    <span class="card-title">频道列表（<%= channels.length %> 个）</span>
  </div>
  <div style="overflow-x:auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>状态</th>
          <th>频道名称</th>
          <th>平台</th>
          <th>直播间 URL</th>
          <th>最后检测</th>
          <th>自动启动</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (channels.length === 0) { %>
          <tr>
            <td colspan="7" style="text-align:center;padding:32px 16px;color:var(--text-2)">
              暂无频道，点击右上角添加
            </td>
          </tr>
        <% } %>
        <% channels.forEach(function(ch) {
          const statusMap = {
            live:    { dotColor: '#f87171', badgeCls: 'badge-red',    label: '直播中', pulse: true  },
            offline: { dotColor: '#6b7280', badgeCls: 'badge-gray',   label: '未开播', pulse: false },
            unknown: { dotColor: '#fbbf24', badgeCls: 'badge-yellow', label: '未检测', pulse: false },
          };
          const s = statusMap[ch.live_status] || statusMap.unknown;
          const platformLabel = {
            douyin:   '抖音',
            bilibili: 'B站',
            kuaishou: '快手',
            youtube:  'YouTube',
            tiktok:   'TikTok',
            custom:   '其他',
          };
        %>
          <tr id="ch-row-<%= ch.id %>">
            <td>
              <div class="flex" style="align-items:center;gap:8px">
                <span class="badge-dot <%= s.pulse ? 'pulse' : '' %>" id="ch-dot-<%= ch.id %>" style="background:<%= s.dotColor %>"></span>
                <span class="badge <%= s.badgeCls %>" id="ch-label-<%= ch.id %>"><%= s.label %></span>
              </div>
            </td>
            <td style="font-weight:500;color:var(--text-1)"><%= ch.name %></td>
            <td style="color:var(--text-2)"><%= platformLabel[ch.platform] || ch.platform %></td>
            <td style="max-width:220px">
              <a href="<%= ch.url %>" target="_blank" class="link" style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= ch.url %>">
                <%= ch.url %>
              </a>
            </td>
            <td style="color:var(--text-2);font-size:12px" id="ch-check-<%= ch.id %>">
              <%= ch.last_check ? new Date(ch.last_check + 'Z').toLocaleString('zh-CN') : '--' %>
            </td>
            <td>
              <div class="flex" style="align-items:center;gap:6px">
                <!-- 自定义 toggle 开关 -->
                <button onclick="toggleAuto(<%= ch.id %>, this)"
                  id="ch-toggle-<%= ch.id %>"
                  title="<%= ch.auto_start ? '自动启动已开启，点击关闭' : '自动启动已关闭，点击开启' %>"
                  style="position:relative;display:inline-flex;width:44px;height:22px;align-items:center;border-radius:12px;border:1px solid <%= ch.auto_start ? 'var(--accent)' : 'rgba(100,116,139,0.55)' %>;cursor:pointer;transition:background .2s,border-color .2s;background:<%= ch.auto_start ? 'var(--accent)' : '#e5e7eb' %>;flex-shrink:0">
                  <span class="toggle-text" style="position:absolute;font-size:10px;font-weight:600;color:<%= ch.auto_start ? '#fff' : '#64748b' %>;left:<%= ch.auto_start ? '7px' : '21px' %>;line-height:1"><%= ch.auto_start ? '开' : '关' %></span>
                  <span class="toggle-knob" style="position:absolute;width:14px;height:14px;border-radius:50%;background:#fff;transition:left .2s;left:<%= ch.auto_start ? '19px' : '3px' %>"></span>
                </button>
                <% if (ch.auto_start && ch.vps_name) { %>
                  <span id="ch-auto-target-<%= ch.id %>" style="font-size:11px;color:var(--text-2)">→ <%= ch.vps_name %></span>
                <% } else { %>
                  <span id="ch-auto-target-<%= ch.id %>" style="font-size:11px;color:var(--text-2)"></span>
                <% } %>
              </div>
            </td>
            <td>
              <div class="flex" style="align-items:center;gap:6px;flex-wrap:wrap">
                <button onclick="checkOne(<%= ch.id %>, this)" class="btn btn-secondary btn-sm">检测</button>
                <button onclick="openEditById(<%= ch.id %>)" class="btn btn-secondary btn-sm">编辑</button>
                <button onclick="useUrl(this.dataset.url)" data-url="<%= ch.url %>" class="btn btn-secondary btn-sm" style="color:#34d399;border-color:rgba(52,211,153,0.3)">用此URL</button>
                <form method="POST" action="/channels/<%= ch.id %>/delete" data-name="<%= ch.name %>" onsubmit="return confirm('确认删除「' + this.dataset.name + '」？')" style="margin:0">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-danger btn-sm">删除</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- 编辑频道弹窗 -->
<div id="edit-modal" class="modal-overlay hidden">
  <div class="modal" style="max-width:520px;max-height:90vh;overflow-y:auto">
    <div class="modal-header">
      <span class="modal-title">编辑频道</span>
      <button class="modal-close" onclick="document.getElementById('edit-modal').classList.add('hidden')">✕</button>
    </div>
    <div class="modal-body">
      <form id="edit-form" class="stack" onsubmit="saveEdit(event)">
        <input type="hidden" id="edit-id">
        <div class="grid" style="grid-template-columns:1fr 1fr;gap:16px">
          <div>
            <label class="form-label">频道名称</label>
            <input id="edit-name" name="name" placeholder="留空自动识别主播名" class="form-input">
          </div>
          <div>
            <label class="form-label">平台</label>
            <select id="edit-platform" name="platform" class="form-select">
              <option value="douyin">抖音</option>
              <option value="bilibili">B站</option>
              <option value="kuaishou">快手</option>
              <option value="youtube">YouTube</option>
              <option value="tiktok">TikTok</option>
              <option value="custom">其他</option>
            </select>
          </div>
        </div>
        <div>
          <label class="form-label">直播间 URL *</label>
          <input id="edit-url" name="url" required placeholder="https://live.douyin.com/xxxxx" class="form-input">
        </div>

        <div style="border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:16px" class="stack">
          <div class="flex" style="align-items:center;gap:8px">
            <input type="checkbox" id="edit-auto-start-cb" onchange="toggleEditAutoFields(this.checked)"
              style="width:16px;height:16px;accent-color:var(--accent);cursor:pointer">
            <label for="edit-auto-start-cb" class="form-label" style="margin:0;cursor:pointer">开播时自动启动转推任务</label>
          </div>
          <div id="edit-auto-fields" class="hidden stack">
            <div>
              <label class="form-label">使用 VPS</label>
              <select id="edit-vps" name="auto_vps_id" class="form-select">
                <option value="">-- 选择 VPS --</option>
                <% vpsList.forEach(function(v) { %>
                  <option value="<%= v.id %>"><%= v.name %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="form-label">推流码</label>
              <select id="edit-sk" name="auto_stream_key_id" onchange="applyStreamKeyDefaultVps('edit')" class="form-select">
                <option value="">-- 选择推流码 --</option>
                <% streamKeys.forEach(function(k) { %>
                  <option value="<%= k.id %>" data-vps="<%= k.default_vps_id || '' %>">[<%= k.platform %>] <%= k.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>

        <div>
          <label class="form-label">备注</label>
          <input id="edit-notes" name="notes" placeholder="可选" class="form-input">
        </div>
        <div class="flex" style="justify-content:flex-end;gap:8px;padding-top:4px">
          <button type="button" onclick="document.getElementById('edit-modal').classList.add('hidden')" class="btn btn-secondary">取消</button>
          <button type="submit" class="btn btn-primary">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 添加频道弹窗 -->
<div id="add-modal" class="modal-overlay hidden">
  <div class="modal" style="max-width:520px;max-height:90vh;overflow-y:auto">
    <div class="modal-header">
      <span class="modal-title">添加直播频道</span>
      <button class="modal-close" onclick="document.getElementById('add-modal').classList.add('hidden')">✕</button>
    </div>
    <div class="modal-body">
      <form method="POST" action="/channels" class="stack" onsubmit="lockSubmit(this)">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="grid" style="grid-template-columns:1fr 1fr;gap:16px">
          <div>
            <label class="form-label">频道名称</label>
            <input name="name" id="add-name" placeholder="留空自动识别主播名" class="form-input">
          </div>
          <div>
            <label class="form-label">平台</label>
            <select name="platform" id="add-platform" class="form-select">
              <option value="douyin">抖音</option>
              <option value="bilibili">B站</option>
              <option value="kuaishou">快手</option>
              <option value="youtube">YouTube</option>
              <option value="tiktok">TikTok</option>
              <option value="custom">其他</option>
            </select>
          </div>
        </div>
        <div>
          <label class="form-label">直播间 URL *</label>
          <input name="url" id="add-url" required onblur="resolveAddMeta()" placeholder="https://live.douyin.com/xxxxx 或 https://live.bilibili.com/xxxxx" class="form-input">
          <p class="form-hint">支持抖音、B站、快手、YouTube 直播间固定地址</p>
        </div>

        <div style="border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:16px" class="stack">
          <div class="flex" style="align-items:center;gap:8px">
            <input type="checkbox" name="auto_start" value="1" id="auto-start-cb" onchange="toggleAutoFields(this.checked)"
              style="width:16px;height:16px;accent-color:var(--accent);cursor:pointer">
            <label for="auto-start-cb" class="form-label" style="margin:0;cursor:pointer">开播时自动启动转推任务</label>
          </div>
          <div id="auto-fields" class="hidden stack">
            <div>
              <label class="form-label">使用 VPS</label>
              <select name="auto_vps_id" id="add-vps" class="form-select">
                <option value="">-- 选择 VPS --</option>
                <% vpsList.forEach(function(v) { %>
                  <option value="<%= v.id %>"><%= v.name %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="form-label">推流码</label>
              <select name="auto_stream_key_id" id="add-sk" onchange="applyStreamKeyDefaultVps('add')" class="form-select">
                <option value="">-- 选择推流码 --</option>
                <% streamKeys.forEach(function(k) { %>
                  <option value="<%= k.id %>" data-vps="<%= k.default_vps_id || '' %>">[<%= k.platform %>] <%= k.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>

        <div>
          <label class="form-label">备注</label>
          <input name="notes" placeholder="可选" class="form-input">
        </div>
        <div class="flex" style="justify-content:flex-end;gap:8px;padding-top:4px">
          <button type="button" onclick="document.getElementById('add-modal').classList.add('hidden')" class="btn btn-secondary">取消</button>
          <button type="submit" class="btn btn-primary">保存</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const _csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
const CHANNELS_DATA = <%- JSON.stringify(channels).replace(/<\/script>/gi, '<\\/script>') %>;

function setChannelData(id, patch) {
  const ch = CHANNELS_DATA.find(item => item.id === id);
  if (ch) Object.assign(ch, patch);
}

function lockSubmit(form) {
  const btn = form.querySelector('button[type="submit"]');
  if (!btn) return true;
  if (btn.disabled) return false;
  btn.dataset.originalText = btn.textContent;
  btn.textContent = '保存中...';
  btn.disabled = true;
  return true;
}

function toggleAutoFields(show) {
  document.getElementById('auto-fields').classList.toggle('hidden', !show);
}

function applyStreamKeyDefaultVps(scope) {
  const skSelect = document.getElementById(scope === 'edit' ? 'edit-sk' : 'add-sk');
  const vpsSelect = document.getElementById(scope === 'edit' ? 'edit-vps' : 'add-vps');
  if (!skSelect || !vpsSelect) return;
  const opt = skSelect.options[skSelect.selectedIndex];
  const vpsId = opt?.dataset?.vps || '';
  if (vpsId && vpsSelect.querySelector('option[value="' + vpsId + '"]')) {
    vpsSelect.value = String(vpsId);
  }
}

async function resolveAddMeta() {
  const urlEl = document.getElementById('add-url');
  const nameEl = document.getElementById('add-name');
  const platformEl = document.getElementById('add-platform');
  if (!urlEl.value.trim() || nameEl.value.trim()) return;
  try {
    const r = await fetch('/channels/resolve-meta', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': _csrf },
      body: JSON.stringify({ url: urlEl.value, platform: platformEl.value }),
    });
    const d = await r.json();
    if (d.ok) {
      nameEl.value = d.name || '';
      urlEl.value = d.url || urlEl.value;
      if (d.platform) platformEl.value = d.platform;
    }
  } catch (_) {}
}

async function checkOne(id, btn) {
  const orig = btn.textContent;
  btn.textContent = '检测中...'; btn.disabled = true;
  try {
    const r = await fetch('/channels/' + id + '/check', { method: 'POST', headers: { 'x-csrf-token': _csrf } });
    const d = await r.json();
    if (d.ok) {
      updateRowStatus(id, d.status);
      showToast(d.msg, d.live ? 'success' : 'info');
    } else {
      showToast(d.msg, 'error');
    }
  } catch(e) { showToast('请求失败', 'error'); }
  btn.textContent = orig; btn.disabled = false;
}

async function checkAll(btn) {
  const orig = btn.textContent;
  btn.textContent = '检测中...'; btn.disabled = true;
  try {
    const r = await fetch('/channels/check-all', { method: 'POST', headers: { 'x-csrf-token': _csrf } });
    const d = await r.json();
    if (d.ok && d.results) {
      d.results.forEach(item => updateRowStatus(item.id, item.status));
      const liveCount = d.results.filter(x => x.live).length;
      const offlineCount = d.results.filter(x => x.status === 'offline').length;
      const unknownCount = d.results.filter(x => x.status === 'unknown').length;
      const msg = `检测完成：${liveCount} 个正在直播，${offlineCount} 个未开播，${unknownCount} 个未检测`;
      showToast(msg, liveCount > 0 ? 'success' : (unknownCount > 0 ? 'warning' : 'info'));
    } else {
      showToast(d.msg || '检测失败', 'error');
    }
  } catch(e) { showToast('请求失败', 'error'); }
  btn.textContent = orig; btn.disabled = false;
}

function updateRowStatus(id, status) {
  const dotEl   = document.getElementById('ch-dot-'   + id);
  const labelEl = document.getElementById('ch-label-' + id);
  const checkEl = document.getElementById('ch-check-' + id);
  if (!dotEl) return;
  const map = {
    live:    { dotColor: '#f87171', badgeCls: 'badge badge-red',    label: '直播中', pulse: true  },
    offline: { dotColor: '#6b7280', badgeCls: 'badge badge-gray',   label: '未开播', pulse: false },
    unknown: { dotColor: '#fbbf24', badgeCls: 'badge badge-yellow', label: '未检测', pulse: false },
  };
  const s = map[status] || map.unknown;
  dotEl.style.background = s.dotColor;
  dotEl.className = 'badge-dot' + (s.pulse ? ' pulse' : '');
  labelEl.className = s.badgeCls;
  labelEl.textContent = s.label;
  if (checkEl) checkEl.textContent = new Date().toLocaleString('zh-CN');
}

async function toggleAuto(id, btn) {
  btn.disabled = true;
  try {
    const r = await fetch('/channels/' + id + '/toggle-auto', { method: 'POST', headers: { 'x-csrf-token': _csrf } });
    const d = await r.json();
    if (d.ok) {
      const on = d.auto_start === 1;
      btn.style.background = on ? 'var(--accent)' : '#e5e7eb';
      btn.style.borderColor = on ? 'var(--accent)' : 'rgba(100,116,139,0.55)';
      btn.title = on ? '自动启动已开启，点击关闭' : '自动启动已关闭，点击开启';
      const knob = btn.querySelector('.toggle-knob');
      const text = btn.querySelector('.toggle-text');
      if (knob) knob.style.left = on ? '19px' : '3px';
      if (text) {
        text.textContent = on ? '开' : '关';
        text.style.left = on ? '7px' : '21px';
        text.style.color = on ? '#fff' : '#64748b';
      }
      const target = document.getElementById('ch-auto-target-' + id);
      if (target) target.textContent = on && d.vps_name ? '→ ' + d.vps_name : '';
      const patch = { auto_start: d.auto_start };
      if (Object.prototype.hasOwnProperty.call(d, 'auto_stream_key_id')) patch.auto_stream_key_id = d.auto_stream_key_id || null;
      if (Object.prototype.hasOwnProperty.call(d, 'auto_vps_id')) patch.auto_vps_id = d.auto_vps_id || null;
      if (Object.prototype.hasOwnProperty.call(d, 'vps_name')) patch.vps_name = d.vps_name || '';
      setChannelData(id, patch);
      showToast(d.msg || (on ? '已开启自动启动' : '已关闭自动启动'), 'info');
    } else {
      showToast(d.msg || '操作失败', 'error');
      if (d.needs_config) openEditById(id);
    }
  } catch(e) {
    showToast('操作失败', 'error');
  } finally {
    btn.disabled = false;
  }
}

function openEditById(id) {
  const ch = CHANNELS_DATA.find(item => item.id === id);
  if (!ch) return;
  document.getElementById('edit-id').value = ch.id;
  document.getElementById('edit-name').value = ch.name || '';
  document.getElementById('edit-url').value = ch.url || '';
  document.getElementById('edit-notes').value = ch.notes || '';
  const platSel = document.getElementById('edit-platform');
  platSel.value = ch.platform || 'douyin';
  const autoOn = !!ch.auto_start;
  document.getElementById('edit-auto-start-cb').checked = autoOn;
  toggleEditAutoFields(autoOn);
  if (autoOn) {
    document.getElementById('edit-vps').value = ch.auto_vps_id || '';
    document.getElementById('edit-sk').value = ch.auto_stream_key_id || '';
    if (!ch.auto_vps_id && ch.auto_stream_key_id) applyStreamKeyDefaultVps('edit');
  }
  document.getElementById('edit-modal').classList.remove('hidden');
}

function toggleEditAutoFields(show) {
  document.getElementById('edit-auto-fields').classList.toggle('hidden', !show);
}

async function saveEdit(e) {
  e.preventDefault();
  const id = document.getElementById('edit-id').value;
  const body = {
    name: document.getElementById('edit-name').value,
    platform: document.getElementById('edit-platform').value,
    url: document.getElementById('edit-url').value,
    notes: document.getElementById('edit-notes').value,
    auto_start: document.getElementById('edit-auto-start-cb').checked ? '1' : '0',
    auto_vps_id: document.getElementById('edit-vps').value,
    auto_stream_key_id: document.getElementById('edit-sk').value,
  };
  try {
    const r = await fetch('/channels/' + id + '/edit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': _csrf },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('edit-modal').classList.add('hidden');
      showToast('频道已更新', 'success');
      setTimeout(() => location.reload(), 800);
    } else {
      showToast(d.msg || '保存失败', 'error');
    }
  } catch(e) { showToast('请求失败', 'error'); }
}

function useUrl(url) {
  navigator.clipboard.writeText(url).then(() => {
    showToast('直播间 URL 已复制；也可以在任务管理的新建任务中直接从频道监控选择', 'success');
  }).catch(() => {
    showToast('URL: ' + url, 'info');
  });
}
</script>
