<div class="dashboard-page" style="width:100%;">
  <div class="page-header">
    <div>
      <div class="page-title">状态面板</div>
      <div class="page-subtitle">实时查看所有任务和 VPS 的运行状态</div>
    </div>
    <a href="/tasks" class="btn btn-primary">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      新建任务
    </a>
  </div>

  <div id="stats-container"
    hx-get="/dashboard/stats"
    hx-trigger="every 15s"
    hx-swap="innerHTML"
    style="display:block;width:100%;max-width:none;margin-left:0;">
    <%- include('partials/stats', { stats, tasks }) %>
  </div>
</div>
