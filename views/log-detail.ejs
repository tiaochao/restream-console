<div class="page-header">
  <div>
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px;">
      <a href="/logs" class="link" style="font-size:13px;">← 返回日志列表</a>
    </div>
    <div class="page-title"><%= task.name || ('任务 #' + task.id) %> 日志</div>
    <div class="page-subtitle"><%= task.vps_name || '--' %> · <span class="monospace" style="font-size:12px;"><%= task.log_file %></span></div>
  </div>
</div>

<div class="card section">
  <div class="card-header">
    <span class="card-title">实时日志（最近 200 行）</span>
    <span style="font-size:12px;color:var(--text-3);">每 5 秒自动刷新</span>
  </div>
  <div id="log-box"
    style="padding:16px;background:#000;border-radius:0 0 12px 12px;max-height:70vh;overflow:auto;"
    hx-get="/logs/<%= task.id %>/tail"
    hx-trigger="every 5s"
    hx-swap="innerHTML">
    <pre style="color:#a1a1aa;font-size:12px;font-family:'JetBrains Mono','Fira Code',monospace;white-space:pre-wrap;word-break:break-all;margin:0;"><%- logContent.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') %></pre>
  </div>
</div>

<script>
  const box = document.getElementById('log-box');
  box.scrollTop = box.scrollHeight;
  document.body.addEventListener('htmx:afterSwap', (e) => {
    if (e.target.id === 'log-box') box.scrollTop = box.scrollHeight;
  });
</script>
