<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})()</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 转推控制台</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0}
    :root{color-scheme:light}
    [data-theme="dark"]{color-scheme:dark}
    body{
      background:#f2faf9;color:#0f1e1c;
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      padding:24px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
      -webkit-font-smoothing:antialiased;transition:background .2s,color .2s;
    }
    [data-theme="dark"] body{background:#060c0b;color:#f1f1f3}
    .card{
      background:#fff;border:1px solid rgba(13,148,136,0.15);
      border-radius:16px;padding:36px 32px;width:100%;max-width:400px;
      box-shadow:0 4px 24px rgba(13,148,136,0.08);
    }
    [data-theme="dark"] .card{background:rgba(255,255,255,0.04);border-color:rgba(20,184,166,0.15);box-shadow:none}
    .logo{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px}
    .logo-icon{width:40px;height:40px;background:linear-gradient(135deg,#0d9488,#14b8a6);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff}
    .logo-text{font-size:20px;font-weight:700;letter-spacing:-0.02em}
    .subtitle{text-align:center;font-size:13px;color:#8aa8a5;margin-bottom:28px}
    .alert-error{padding:10px 14px;background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.2);border-radius:8px;color:#dc2626;font-size:13px;margin-bottom:20px}
    [data-theme="dark"] .alert-error{background:rgba(239,68,68,0.12);border-color:rgba(239,68,68,0.25);color:#f87171}
    label{display:block;font-size:12.5px;font-weight:500;color:#3d5553;margin-bottom:6px}
    [data-theme="dark"] label{color:#a1a1aa}
    input{width:100%;padding:9px 12px;background:#f8fffe;border:1px solid rgba(0,0,0,0.1);border-radius:8px;color:#0f1e1c;font-size:14px;outline:none;transition:border-color .15s,box-shadow .15s;font-family:inherit}
    [data-theme="dark"] input{background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:#f1f1f3}
    input:focus{border-color:rgba(13,148,136,0.55);box-shadow:0 0 0 3px rgba(13,148,136,0.12)}
    input::placeholder{color:#8aa8a5}
    [data-theme="dark"] input::placeholder{color:#52525b}
    .field{margin-bottom:16px}
    .btn{width:100%;padding:10px;background:linear-gradient(135deg,#0d9488,#14b8a6);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .15s;margin-top:4px;font-family:inherit}
    .btn:hover{opacity:0.88}
    .footer-link{text-align:center;font-size:13px;color:#8aa8a5;margin-top:20px}
    .footer-link a{color:#0d9488;text-decoration:none}
    [data-theme="dark"] .footer-link a{color:#2dd4bf}
    .footer-link a:hover{text-decoration:underline}
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-icon">⬡</div>
      <div class="logo-text">转推控制台</div>
    </div>
    <p class="subtitle">登录后管理你的转推任务</p>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="field">
        <label for="username">用户名</label>
        <input type="text" id="username" name="username" required autofocus autocomplete="username" placeholder="admin">
      </div>
      <div class="field">
        <label for="password">密码</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="请输入密码">
      </div>
      <button type="submit" class="btn">登 录</button>
    </form>

    <% if (allowRegistration) { %>
      <p class="footer-link">还没有账号？<a href="/register">创建账号</a></p>
    <% } %>
  </div>
</body>
</html>
