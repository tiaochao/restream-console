<div class="page-header">
  <h2 class="page-title">日志</h2>
  <p class="page-subtitle">查看各任务的运行日志</p>
</div>

<div class="card section">
  <div class="card-header">
    <span class="card-title">有日志记录的任务</span>
  </div>
  <div style="overflow-x:auto;">
    <table class="data-table">
      <thead>
        <tr>
          <th>任务</th>
          <th>VPS</th>
          <th>状态</th>
          <th>日志文件</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (tasks.length === 0) { %>
          <tr>
            <td colspan="5" style="text-align:center;padding:32px;color:var(--text-2);">暂无日志记录</td>
          </tr>
        <% } %>
        <% tasks.forEach(function(t) {
          const badgeMap = {
            running: 'badge-green',
            source_retrying: 'badge-yellow',
            target_lost: 'badge-red',
            stalled: 'badge-yellow',
            restarting: 'badge-blue',
            waiting_live: 'badge-blue',
            blocked: 'badge-orange',
            error:   'badge-red',
            stopped: 'badge-gray',
            idle:    'badge-gray'
          };
          const labelMap = {
            running: '推流中',
            source_retrying: '重试解析',
            target_lost: '目标断流',
            stalled: '卡死',
            restarting: '重启中',
            waiting_live: '等待开播',
            blocked: '已封锁',
            error: '错误',
            stopped: '已停止',
            idle: '待机'
          };
          const badge = badgeMap[t.status] || 'badge-gray';
        %>
          <tr>
            <td style="font-weight:500;color:var(--text-1);"><%= t.name || ('任务 #' + t.id) %></td>
            <td style="color:var(--text-2);"><%= t.vps_name || '--' %></td>
            <td><span class="badge <%= badge %>"><%= labelMap[t.status] || t.status %></span></td>
            <td class="monospace" style="font-size:12px;color:var(--text-2);max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= t.log_file %>
            </td>
            <td>
              <a href="/logs/<%= t.id %>" class="btn btn-secondary btn-sm">查看日志</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
