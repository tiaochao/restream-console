<div class="space-y-6">
  <h2 class="text-2xl font-bold">📋 日志</h2>

  <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">
    <div class="p-4 border-b border-gray-700">
      <h3 class="text-lg font-semibold">有日志记录的任务</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-700">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">任务</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">VPS</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">状态</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">日志文件</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-700">
          <% if (tasks.length === 0) { %>
            <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500">暂无日志记录</td></tr>
          <% } %>
          <% tasks.forEach(function(t) {
            const statusMap = { running:'text-emerald-400', error:'text-red-400', stopped:'text-gray-400', idle:'text-gray-500' };
          %>
            <tr class="hover:bg-gray-750">
              <td class="px-4 py-3 text-sm"><%= t.name || ('任务 #' + t.id) %></td>
              <td class="px-4 py-3 text-sm text-gray-300"><%= t.vps_name || '--' %></td>
              <td class="px-4 py-3 text-sm <%= statusMap[t.status] || 'text-gray-400' %>"><%= t.status %></td>
              <td class="px-4 py-3 text-sm font-mono text-gray-400 text-xs"><%= t.log_file %></td>
              <td class="px-4 py-3">
                <a href="/logs/<%= t.id %>" class="text-blue-400 hover:text-blue-300 text-sm px-2 py-1 rounded border border-blue-900 hover:border-blue-700 transition-colors">
                  查看日志
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
