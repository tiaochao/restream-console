<!-- 统计卡片 + 任务表 — 用于 HTMX 轮询局部刷新 -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-gray-800 rounded-xl shadow-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-400 text-sm">VPS 在线</p>
        <p class="text-2xl font-bold text-emerald-400"><%= stats.onlineVps %>/<%= stats.totalVps %></p>
      </div>
      <div class="text-3xl">🖥️</div>
    </div>
  </div>
  <div class="bg-gray-800 rounded-xl shadow-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-400 text-sm">运行中任务</p>
        <p class="text-2xl font-bold text-emerald-400"><%= stats.runningTasks %></p>
      </div>
      <div class="text-3xl">▶️</div>
    </div>
  </div>
  <div class="bg-gray-800 rounded-xl shadow-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-400 text-sm">错误任务</p>
        <p class="text-2xl font-bold text-red-400"><%= stats.errorTasks %></p>
      </div>
      <div class="text-3xl">⚠️</div>
    </div>
  </div>
  <div class="bg-gray-800 rounded-xl shadow-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-400 text-sm">总任务数</p>
        <p class="text-2xl font-bold text-white"><%= stats.totalTasks %></p>
      </div>
      <div class="text-3xl">📋</div>
    </div>
  </div>
</div>

<!-- 任务状态表 -->
<div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">
  <div class="p-4 border-b border-gray-700">
    <h3 class="text-lg font-semibold">任务状态</h3>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gray-700">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">状态</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">VPS</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">平台</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">来源直播间</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">密钥</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">时长</th>
          <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">备注</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-700">
        <% if (tasks.length === 0) { %>
          <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">暂无任务</td></tr>
        <% } %>
        <% tasks.forEach(function(t) {
          const statusMap = {
            running:      { dot: 'bg-emerald-500 animate-pulse', text: 'text-emerald-400', label: '推流中' },
            stalled:      { dot: 'bg-amber-500 animate-pulse',   text: 'text-amber-400',   label: '卡死' },
            restarting:   { dot: 'bg-blue-500 animate-pulse',    text: 'text-blue-400',    label: '重启中' },
            waiting_live: { dot: 'bg-purple-500 animate-pulse',  text: 'text-purple-400',  label: '等待开播' },
            error:        { dot: 'bg-red-500',                   text: 'text-red-400',     label: '错误' },
            blocked:      { dot: 'bg-orange-500',                text: 'text-orange-400',  label: '已封锁' },
            stopped:      { dot: 'bg-gray-500',                  text: 'text-gray-400',    label: '已停止' },
            idle:         { dot: 'bg-gray-600',                  text: 'text-gray-400',    label: '待机' },
          };
          const s = statusMap[t.status] || statusMap.idle;
          const pIcon = { youtube: '▶️', tiktok: '🎵', custom: '📺' };
          let duration = '--';
          if (t.started_at && t.status === 'running') {
            const sec = Math.floor((Date.now() - new Date(t.started_at + 'Z').getTime()) / 1000);
            duration = [Math.floor(sec/3600), Math.floor((sec%3600)/60), sec%60].map(n=>String(n).padStart(2,'0')).join(':');
          }
        %>
          <tr class="hover:bg-gray-750">
            <td class="px-4 py-3">
              <div class="flex items-center space-x-2">
                <span class="inline-block w-3 h-3 <%= s.dot %> rounded-full"></span>
                <span class="text-sm <%= s.text %>"><%= s.label %></span>
              </div>
            </td>
            <td class="px-4 py-3 text-sm"><%= t.vps_name || '--' %></td>
            <td class="px-4 py-3 text-sm"><%= pIcon[t.platform] || '📺' %></td>
            <td class="px-4 py-3 text-sm max-w-xs">
              <a href="<%= t.source_url %>" target="_blank" class="block truncate text-sky-400 hover:text-sky-300" title="<%= t.source_url %>">
                <%= t.source_url %>
              </a>
            </td>
            <td class="px-4 py-3 text-sm font-mono text-gray-300">
              <%= t.stream_key ? t.stream_key.substring(0,4) + '****' : '--' %>
            </td>
            <td class="px-4 py-3 text-sm font-mono text-gray-300 whitespace-nowrap"><%= duration %></td>
            <td class="px-4 py-3 text-sm text-gray-400">
              <div class="truncate max-w-xs" title="<%= t.notes || '' %>"><%= t.notes || '--' %></div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
