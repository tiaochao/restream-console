<div class="stack" style="max-width:760px;">
  <div class="page-header">
    <div class="page-title">设置</div>
    <div class="page-subtitle">系统参数、Cookie 配置与账号管理</div>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <!-- 直播监控 & Cookie -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">直播监控设置</div>
    </div>
    <div class="modal-body stack">
      <div class="alert alert-info" style="font-size:13px;">
        监控检测优先使用本地 HTTP 直连平台 API（无需 VPS），对不支持的平台才走 SSH yt-dlp。
      </div>

      <!-- Cookie 配置 -->
      <form method="POST" action="/settings/cookies" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="form-label">
            抖音 Cookie
            <span style="font-size:12px;color:var(--text-3);font-weight:400;margin-left:8px;">（用于检测开播状态，填入后识别成功率更高）</span>
          </label>
          <textarea name="douyin_cookies" rows="3" placeholder="ttwid=xxx; passport_csrf_token=xxx; ..."
            class="form-textarea" style="font-family:monospace;resize:vertical;"><%= cfg.douyin_cookies %></textarea>
          <div class="form-hint" style="display:flex;flex-direction:column;gap:4px;margin-top:6px;">
            <span>获取方式：浏览器打开 <a href="https://live.douyin.com" target="_blank" class="link">live.douyin.com</a>，登录后按 F12 → Network → 找任意请求 → 复制 Cookie 请求头的值</span>
            <span>至少需要 <code style="background:rgba(0,0,0,0.4);padding:1px 5px;border-radius:4px;font-family:monospace;font-size:11px;">ttwid</code> 和 <code style="background:rgba(0,0,0,0.4);padding:1px 5px;border-radius:4px;font-family:monospace;font-size:11px;">passport_csrf_token</code></span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
          <button type="submit" class="btn btn-primary">保存 Cookie</button>
          <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0;">
            <input id="test-url" type="text" placeholder="抖音直播间 URL（留空用默认测试地址）"
              class="form-input" style="flex:1;min-width:0;">
            <button type="button" onclick="testCookie()" id="test-btn" class="btn btn-secondary" style="white-space:nowrap;">
              测试检测
            </button>
          </div>
          <span id="test-result" style="font-size:13px;"></span>
        </div>
      </form>

      <!-- 检测间隔 -->
      <form method="POST" action="/settings/general" style="border-top:1px solid rgba(255,255,255,0.08);padding-top:20px;" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="start_delay" value="<%= cfg.start_delay %>">
        <input type="hidden" name="stall_timeout" value="<%= cfg.stall_timeout %>">
        <input type="hidden" name="max_tasks_per_vps" value="<%= cfg.max_tasks_per_vps %>">
        <div>
          <label class="form-label">自动检测间隔（分钟）</label>
          <input type="number" name="monitor_interval" value="<%= cfg.monitor_interval %>" min="1" max="60"
            class="form-input" style="width:140px;">
          <div class="form-hint">修改后需重启服务生效，当前为 <%= cfg.monitor_interval %> 分钟</div>
        </div>
        <div>
          <button type="submit" class="btn btn-secondary">保存间隔</button>
        </div>
      </form>
    </div>
  </div>

  <!-- 任务调度设置 -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">任务调度</div>
    </div>
    <div class="modal-body">
      <form method="POST" action="/settings/general" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="monitor_interval" value="<%= cfg.monitor_interval %>">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
          <div>
            <label class="form-label">启动间隔（秒）</label>
            <input type="number" name="start_delay" value="<%= cfg.start_delay %>" min="0" max="60" class="form-input">
            <div class="form-hint">多任务连续启动时的间隔</div>
          </div>
          <div>
            <label class="form-label">无数据超时（秒）</label>
            <input type="number" name="stall_timeout" value="<%= cfg.stall_timeout %>" min="30" max="600" class="form-input">
            <div class="form-hint">日志停止更新后触发自动重启</div>
          </div>
          <div>
            <label class="form-label">每 VPS 任务上限</label>
            <input type="number" name="max_tasks_per_vps" value="<%= cfg.max_tasks_per_vps %>" min="1" max="20" class="form-input">
            <div class="form-hint">超过则拒绝启动新任务</div>
          </div>
        </div>
        <div>
          <button type="submit" class="btn btn-primary">保存设置</button>
        </div>
      </form>
    </div>
  </div>

  <!-- 修改密码 -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">修改登录密码</div>
    </div>
    <div class="modal-body">
      <form method="POST" action="/settings/password" class="stack" style="max-width:400px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="form-label">当前密码</label>
          <input type="password" name="current_password" required class="form-input">
        </div>
        <div>
          <label class="form-label">新密码</label>
          <input type="password" name="new_password" required minlength="6" class="form-input">
        </div>
        <div>
          <label class="form-label">确认新密码</label>
          <input type="password" name="confirm_password" required minlength="6" class="form-input">
        </div>
        <div>
          <button type="submit" class="btn btn-primary">更新密码</button>
        </div>
      </form>
    </div>
  </div>

  <!-- VPS 依赖说明 -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">转推 VPS 依赖</div>
    </div>
    <div class="modal-body stack">
      <p style="color:var(--text-2);font-size:13px;">可在 VPS 管理页点「安装依赖」自动安装，或手动执行：</p>
      <pre style="background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:16px;font-size:12px;font-family:monospace;color:var(--text-2);overflow-x:auto;white-space:pre;line-height:1.7;">apt install -y ffmpeg curl wget
# 下载 yt-dlp 独立二进制（无需 Python）
wget -O /usr/local/bin/yt-dlp https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_linux
chmod +x /usr/local/bin/yt-dlp</pre>
      <div class="form-hint">注：开播检测已改用本地直连 API，VPS 仅用于实际转推（yt-dlp + FFmpeg）。</div>
    </div>
  </div>
</div>

<script>
const _csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';

async function testCookie() {
  const btn = document.getElementById('test-btn');
  const url = document.getElementById('test-url').value.trim();
  const resultEl = document.getElementById('test-result');
  btn.disabled = true; btn.textContent = '检测中...';
  resultEl.textContent = '';
  try {
    const fd = new FormData();
    if (url) fd.append('test_url', url);
    const r = await fetch('/settings/test-douyin', { method: 'POST', body: new URLSearchParams(fd) });
    const d = await r.json();
    resultEl.textContent = d.msg;
    resultEl.style.color = d.ok ? (d.live ? '#f87171' : 'var(--text-3)') : '#f87171';
  } catch(e) {
    resultEl.textContent = '请求失败';
    resultEl.style.color = '#f87171';
  }
  btn.disabled = false; btn.textContent = '测试检测';
}
</script>
