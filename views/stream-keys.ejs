<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h2 class="text-2xl font-bold">🔑 推流码库</h2>
    <button onclick="document.getElementById('add-modal').classList.remove('hidden')"
      class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
      + 添加推流码
    </button>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="px-4 py-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm"><%= error %></div>
  <% } %>

  <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">
    <div class="p-4 border-b border-gray-700">
      <h3 class="text-lg font-semibold">推流码列表（<%= keys.length %> 条）</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-700">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">名称</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">平台</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">RTMP 地址</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">推流密钥</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">备注</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-300">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-700">
          <% if (keys.length === 0) { %>
            <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500">暂无推流码，点击右上角添加</td></tr>
          <% } %>
          <% keys.forEach(function(k) {
            const platformIcon = { youtube: '▶️ YouTube', tiktok: '🎵 TikTok', custom: '📺 自定义' };
          %>
            <tr class="hover:bg-gray-750" id="key-row-<%= k.id %>">
              <td class="px-4 py-3 text-sm font-medium"><%= k.name %></td>
              <td class="px-4 py-3 text-sm text-gray-300"><%= platformIcon[k.platform] || k.platform %></td>
              <td class="px-4 py-3 text-sm font-mono text-gray-400 max-w-xs">
                <span class="block truncate" title="<%= k.rtmp_url %>"><%= k.rtmp_url %></span>
              </td>
              <td class="px-4 py-3 text-sm font-mono text-gray-300">
                <span class="cursor-pointer" onclick="toggleKey(this, '<%= k.stream_key %>')" title="点击显示/隐藏">
                  <span class="key-masked"><%= k.stream_key.substring(0, 4) %>****</span>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= k.notes || '--' %></td>
              <td class="px-4 py-3">
                <div class="flex items-center space-x-2">
                  <button onclick="verifyKey(<%= k.id %>, this)"
                    class="text-amber-400 hover:text-amber-300 text-sm px-2 py-1 rounded border border-amber-800 hover:border-amber-600 transition-colors">
                    校验
                  </button>
                  <form method="POST" action="/stream-keys/<%= k.id %>/delete" onsubmit="return confirm('确认删除推流码「<%= k.name %>」？')">
                    <button type="submit" class="text-red-400 hover:text-red-300 text-sm px-2 py-1 rounded border border-red-900 hover:border-red-700 transition-colors">
                      删除
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- 添加推流码弹窗 -->
<div id="add-modal" class="hidden fixed inset-0 bg-black bg-opacity-60 z-40 flex items-center justify-center p-4">
  <div class="bg-gray-800 rounded-xl shadow-xl w-full max-w-lg">
    <div class="flex items-center justify-between p-6 border-b border-gray-700">
      <h3 class="text-lg font-semibold">添加推流码</h3>
      <button onclick="document.getElementById('add-modal').classList.add('hidden')" class="text-gray-400 hover:text-white text-xl">✕</button>
    </div>
    <form method="POST" action="/stream-keys" class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">名称 *</label>
          <input name="name" required placeholder="我的 YouTube 推流码"
            class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">平台</label>
          <select name="platform" id="sk-platform" onchange="setSkRtmp(this.value)"
            class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <option value="youtube">YouTube</option>
            <option value="tiktok">TikTok / 抖音</option>
            <option value="custom">自定义</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">RTMP 推流地址 *</label>
        <input name="rtmp_url" id="sk-rtmp-url" required value="rtmp://a.rtmp.youtube.com/live2"
          placeholder="rtmp://a.rtmp.youtube.com/live2"
          class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm font-mono focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <p class="text-xs text-gray-500 mt-1">不含密钥部分</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">推流密钥 *</label>
        <input name="stream_key" required placeholder="xxxx-xxxx-xxxx-xxxx"
          class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm font-mono focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">备注</label>
        <input name="notes" placeholder="可选，如：主频道 #1"
          class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
      <div class="flex justify-end space-x-3 pt-2">
        <button type="button" onclick="document.getElementById('add-modal').classList.add('hidden')"
          class="px-4 py-2 text-gray-400 hover:text-white text-sm transition-colors">取消</button>
        <button type="submit"
          class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium transition-colors">保存</button>
      </div>
    </form>
  </div>
</div>

<!-- 校验结果弹窗 -->
<div id="verify-modal" class="hidden fixed inset-0 bg-black bg-opacity-60 z-40 flex items-center justify-center p-4">
  <div class="bg-gray-800 rounded-xl shadow-xl w-full max-w-lg">
    <div class="flex items-center justify-between p-6 border-b border-gray-700">
      <h3 class="text-lg font-semibold">推流码校验结果</h3>
      <button onclick="document.getElementById('verify-modal').classList.add('hidden')" class="text-gray-400 hover:text-white text-xl">✕</button>
    </div>
    <div class="p-6 space-y-4">
      <div id="verify-status" class="px-4 py-3 rounded-lg text-sm"></div>
      <div id="verify-output-wrap" class="hidden">
        <p class="text-xs text-gray-400 mb-2">FFmpeg 输出（最后 5 行）：</p>
        <pre id="verify-output" class="bg-gray-900 rounded-lg p-3 text-xs text-gray-300 overflow-auto max-h-40 whitespace-pre-wrap"></pre>
      </div>
      <div class="flex justify-end">
        <button onclick="document.getElementById('verify-modal').classList.add('hidden')"
          class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm transition-colors">关闭</button>
      </div>
    </div>
  </div>
</div>

<script>
const SK_RTMP_MAP = {
  youtube: 'rtmp://a.rtmp.youtube.com/live2',
  tiktok:  'rtmp://push.tiktokv.com/live',
  custom:  ''
};
function setSkRtmp(p) {
  if (p !== 'custom') document.getElementById('sk-rtmp-url').value = SK_RTMP_MAP[p] || '';
}

function toggleKey(el, fullKey) {
  const span = el.querySelector('.key-masked');
  if (span.dataset.shown === '1') {
    span.textContent = fullKey.substring(0, 4) + '****';
    span.dataset.shown = '';
  } else {
    span.textContent = fullKey;
    span.dataset.shown = '1';
  }
}

async function verifyKey(id, btn) {
  const orig = btn.textContent;
  btn.textContent = '校验中...'; btn.disabled = true;

  const statusEl = document.getElementById('verify-status');
  const outputWrap = document.getElementById('verify-output-wrap');
  const outputEl = document.getElementById('verify-output');

  statusEl.textContent = '正在发送测试信号，最长约 15 秒……';
  statusEl.className = 'px-4 py-3 rounded-lg text-sm bg-blue-900/50 border border-blue-700 text-blue-300';
  outputWrap.classList.add('hidden');
  document.getElementById('verify-modal').classList.remove('hidden');

  try {
    const r = await fetch('/stream-keys/' + id + '/verify', { method: 'POST' });
    const d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ ' + d.msg;
      statusEl.className = 'px-4 py-3 rounded-lg text-sm bg-emerald-900/50 border border-emerald-700 text-emerald-300';
    } else {
      statusEl.textContent = '✗ ' + d.msg;
      statusEl.className = 'px-4 py-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
    }
    if (d.output) {
      outputEl.textContent = d.output;
      outputWrap.classList.remove('hidden');
    }
  } catch(e) {
    statusEl.textContent = '请求失败：' + e.message;
    statusEl.className = 'px-4 py-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
  }

  btn.textContent = orig; btn.disabled = false;
}
</script>
