async function pingAll(btn) {
  const orig = btn.textContent;
  btn.textContent = '检测中...'; btn.disabled = true;
  try {
    const r = await fetch('/vps/ping-all', {
      method: 'POST',
      headers: _csrf ? { 'x-csrf-token': _csrf } : {},
    });
